<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext (http://) only for the specific legacy Icecast/Caster stream
  hosts that do not yet serve HTTPS. All other traffic uses HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Legacy stream hosts that only serve http:// -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- KFM 93.3 -->
        <domain includeSubdomains="true">radio.kfm.co.ug</domain>
        <!-- Sanyu FM -->
        <domain includeSubdomains="true">s44.myradiostream.com</domain>
        <!-- Beat FM -->
        <domain includeSubdomains="true">5230.cloudrad.io</domain>
        <!-- Rock FM -->
        <domain includeSubdomains="true">titan.shoutca.st</domain>
        <!-- KIIS FM -->
        <domain includeSubdomains="true">14867.cloudrad.io</domain>
        <!-- Kaboozi FM -->
        <domain includeSubdomains="true">162.244.80.52</domain>
        <!-- Joy Hits -->
        <domain includeSubdomains="true">joyhits.online</domain>
        <!-- Favour FM Gulu -->
        <domain includeSubdomains="true">us5new.listen2myradio.com</domain>
        <!-- Christ FM 91.6 -->
        <domain includeSubdomains="true">s39.myradiostream.com</domain>
    </domain-config>
</network-security-config>
